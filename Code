import cv2
import yt_dlp
from ultralytics import YOLO
import numpy as np
from PIL import Image
from IPython.display import display
import io

# --- 1. CONFIGURATION & STREAM FETCHING ---
def get_youtube_stream_url(youtube_url):
    """Extracts the direct stream link from a YouTube URL."""
    ydl_opts = {'format': 'best[ext=mp4]', 'quiet': True, 'no_warnings': True}
    with yt_dlp.YoutubeDL(ydl_opts) as ydl:
        try:
            info = ydl.extract_info(youtube_url, download=False)
            return info['url']
        except Exception as e:
            print(f"Error fetching stream: {e}")
            return None

# --- 2. INITIALIZATION ---
youtube_url = input("Enter YouTube URL: ")
stream_url = get_youtube_stream_url(youtube_url)

if not stream_url:
    print("Invalid URL or stream unreachable.")
else:
    # Load model once
    model = YOLO('yolov8n.pt') 
    cap = cv2.VideoCapture(stream_url)
    
    # Create a persistent handle for flicker-free notebook updates
    display_handle = display(None, display_id=True)

    try:
        while cap.isOpened():
            ret, frame = cap.read()
            if not ret:
                break

            # Optimization: Resize frame to reduce processing load
            frame = cv2.resize(frame, (640, 480))
            
            # --- 3. INFERENCE & FEATURE EXTRACTION ---
            # Using built-in class filtering [0] is 'person' in COCO
            results = model(frame, classes=[0], verbose=False)[0]
            
            # Count the number of detections
            human_count = len(results.boxes)

            # Draw Detections
            for box in results.boxes:
                # Get coordinates and confidence
                x1, y1, x2, y2 = map(int, box.xyxy[0])
                conf = float(box.conf[0])
                
                # Draw bounding box
                cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 0), 2)
                # Label with confidence
                cv2.putText(frame, f'P {conf:.2f}', (x1, y1 - 10), 
                            cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 0), 2)

            # --- 4. ADDED FEATURES: HUD & OVERLAYS ---
            # Background rectangle for text readability
            cv2.rectangle(frame, (0, 0), (200, 50), (0, 0, 0), -1)
            # Display real-time human count
            cv2.putText(frame, f'Humans: {human_count}', (10, 35), 
                        cv2.FONT_HERSHEY_SIMPLEX, 1, (255, 255, 255), 2)

            # --- 5. BROWSER-SAFE DISPLAY ---
            # Convert BGR (OpenCV) to RGB (PIL/Browser)
            _, encoded_img = cv2.imencode('.jpg', frame)
            display_handle.update(Image.open(io.BytesIO(encoded_img)))

    except KeyboardInterrupt:
        print("\nStream stopped by user.")
    finally:
        cap.release()
        print("Resources released.")
